<UserControl x:Class="ATAS.Indicators.Technical.Editors.LevelSettingsEditor"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:technical="clr-namespace:ATAS.Indicators.Technical"
             xmlns:converters="clr-namespace:Utils.Windows.Converters;assembly=Utils.Windows"
             mc:Ignorable="d"
             d:DesignHeight="20" d:DesignWidth="300">

    <UserControl.Resources>
        <converters:ColorToBrushConverter x:Key="ColorToBrushConverter" />
        <converters:LocalizedEnumValueConverter x:Key="EnumToLocalizedStringConverter" />
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Enabled checkbox -->
        <CheckBox Grid.Column="0" 
                  IsChecked="{Binding Enabled}"
                  VerticalAlignment="Center"
                  Margin="0,0,8,0" />

        <!-- Visual representation -->
        <Border Grid.Column="1" 
                Width="80" Height="20" 
                BorderThickness="1"
                BorderBrush="Gray"
                Margin="0,0,0,0"
                VerticalAlignment="Center"
                HorizontalAlignment="Left">
            <Canvas>
                <!-- Chart area background -->
                <Rectangle Fill="Transparent" Width="78" Height="18" Canvas.Left="0" Canvas.Top="0" />
                
                <!-- Chart visualization (candles/bars) -->
                <!-- Previous bars (smaller) -->
                <Rectangle Fill="LightGray" Width="2" Height="8" Canvas.Left="15" Canvas.Top="5" />
                <Rectangle Fill="LightGray" Width="2" Height="12" Canvas.Left="20" Canvas.Top="3" />
                <Rectangle Fill="LightGray" Width="2" Height="6" Canvas.Top="7" Canvas.Left="25" />
                <Rectangle Fill="LightGray" Width="2" Height="10" Canvas.Left="30" Canvas.Top="4" />
                <Rectangle Fill="LightGray" Width="2" Height="7" Canvas.Left="35" Canvas.Top="6" />
                <Rectangle Fill="LightGray" Width="2" Height="9" Canvas.Left="40" Canvas.Top="5" />
                
                <!-- Current bar (highlighted) -->
                <Rectangle Fill="DarkGray" Width="3" Height="14" Canvas.Left="44" Canvas.Top="2" />
                
                <!-- Price axis area (right edge) -->
                <Rectangle Fill="Transparent" Stroke="Gray" StrokeThickness="0.5" 
                          Width="8" Height="18" Canvas.Left="70" Canvas.Top="0" />
                
                <!-- Main line (LineType) -->
                <!-- Full line -->
                <Line X1="5" Y1="9" X2="70" Y2="9" 
                      Stroke="{Binding Color, Converter={StaticResource ColorToBrushConverter}}" 
                      StrokeThickness="1">
                    <Line.Style>
                        <Style TargetType="Line">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding LineType}" Value="Full">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                                <!-- Line style triggers -->
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding LineType}" Value="Full" />
                                        <Condition Binding="{Binding LineStyle}" Value="Dash" />
                                    </MultiDataTrigger.Conditions>
                                    <Setter Property="StrokeDashArray" Value="4,2" />
                                </MultiDataTrigger>
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding LineType}" Value="Full" />
                                        <Condition Binding="{Binding LineStyle}" Value="Dot" />
                                    </MultiDataTrigger.Conditions>
                                    <Setter Property="StrokeDashArray" Value="1,2" />
                                </MultiDataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Line.Style>
                </Line>
                
                <!-- Bar line (from current bar to price axis) -->
                <Line X1="48" Y1="9" X2="70" Y2="9" 
                      Stroke="{Binding Color, Converter={StaticResource ColorToBrushConverter}}" 
                      StrokeThickness="1">
                    <Line.Style>
                        <Style TargetType="Line">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding LineType}" Value="Bar">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                                <!-- Line style triggers -->
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding LineType}" Value="Bar" />
                                        <Condition Binding="{Binding LineStyle}" Value="Dash" />
                                    </MultiDataTrigger.Conditions>
                                    <Setter Property="StrokeDashArray" Value="4,2" />
                                </MultiDataTrigger>
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding LineType}" Value="Bar" />
                                        <Condition Binding="{Binding LineStyle}" Value="Dot" />
                                    </MultiDataTrigger.Conditions>
                                    <Setter Property="StrokeDashArray" Value="1,2" />
                                </MultiDataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Line.Style>
                </Line>
                
                <!-- Price label (right side) -->
                <Rectangle Width="8" Height="6" Canvas.Left="70" Canvas.Top="6"
                          Stroke="{Binding Color, Converter={StaticResource ColorToBrushConverter}}" 
                          StrokeThickness="1" Fill="Transparent">
                    <Rectangle.Visibility>
                        <Binding Path="ShowPrice">
                            <Binding.Converter>
                                <BooleanToVisibilityConverter />
                            </Binding.Converter>
                        </Binding>
                    </Rectangle.Visibility>
                </Rectangle>
                
                <!-- Label positions -->
                <!-- Left label (chart left edge) -->
                <Rectangle Width="8" Height="4" Canvas.Left="2" Canvas.Top="7"
                          Stroke="{Binding Color, Converter={StaticResource ColorToBrushConverter}}" 
                          StrokeThickness="1" Fill="Transparent">
                    <Rectangle.Style>
                        <Style TargetType="Rectangle">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding LabelPosition}" Value="Left">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Rectangle.Style>
                </Rectangle>
                
                <!-- Bar label (right of current bar) -->
                <Rectangle Width="8" Height="4" Canvas.Left="49" Canvas.Top="7"
                          Stroke="{Binding Color, Converter={StaticResource ColorToBrushConverter}}" 
                          StrokeThickness="1" Fill="Transparent">
                    <Rectangle.Style>
                        <Style TargetType="Rectangle">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding LabelPosition}" Value="Bar">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Rectangle.Style>
                </Rectangle>
                
                <!-- Right label (chart area, before price axis) -->
                <Rectangle Width="8" Height="4" Canvas.Left="60" Canvas.Top="7"
                          Stroke="{Binding Color, Converter={StaticResource ColorToBrushConverter}}" 
                          StrokeThickness="1" Fill="Transparent">
                    <Rectangle.Style>
                        <Style TargetType="Rectangle">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding LabelPosition}" Value="Right">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Rectangle.Style>
                </Rectangle>
            </Canvas>
        </Border>
    </Grid>

</UserControl>